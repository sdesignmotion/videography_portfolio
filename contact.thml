<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Contact - s_design</title>
    <link rel="stylesheet" href="css/styles.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
</head>
<body>
    <!-- Navigation -->
    <nav class="navbar">
        <div class="logo-container">
            <svg viewBox="0 0 200 200" xmlns="http://www.w3.org/2000/svg" class="logo-svg">
                <defs>
                    <linearGradient id="goldGradient" x1="0%" y1="0%" x2="100%" y2="100%">
                        <stop offset="0%" style="stop-color:#D4A574;stop-opacity:1" />
                        <stop offset="100%" style="stop-color:#E8BF8F;stop-opacity:1" />
                    </linearGradient>
                </defs>
                <path d="M60 80 Q40 100 50 130 Q60 140 80 135 Q70 115 75 95 Z" fill="url(#goldGradient)"/>
                <path d="M140 80 Q160 100 150 130 Q140 140 120 135 Q130 115 125 95 Z" fill="url(#goldGradient)"/>
                <circle cx="100" cy="100" r="20" fill="url(#goldGradient)"/>
                <path d="M100 80 L110 90 L100 100 L90 90 Z" fill="#000"/>
            </svg>
        </div>

        <ul class="nav-links">
            <li><a href="index.html">Portfolio</a></li>
            <li><a href="#about">Who I am</a></li>
            <li><a href="#contact">Connect</a></li>
            <li><a href="https://instagram.com" target="_blank"><i class="fab fa-instagram"></i></a></li>
        </ul>
    </nav>

    <!-- Contact Section -->
    <section class="contact-page">
        <h1>Let's Work Together</h1>
        <div class="contact-container">
            <div class="contact-form-wrapper">
                <form class="contact-form" id="contactForm">
                    <div class="form-group">
                        <input type="text" placeholder="Your Name" required>
                    </div>
                    <div class="form-group">
                        <input type="email" placeholder="Your Email" required>
                    </div>
                    <div class="form-group">
                        <input type="text" placeholder="Subject">
                    </div>
                    <div class="form-group">
                        <textarea placeholder="Your Message" rows="6" required></textarea>
                    </div>
                    <button type="submit" class="submit-btn">Send Message</button>
                </form>
            </div>

            <div class="contact-info-wrapper">
                <h2>Contact Information</h2>
                <div class="info-item">
                    <i class="fas fa-envelope"></i>
                    <div>
                        <h4>Email</h4>
                        <a href="mailto:hello@sdesign.com">hello@sdesign.com</a>
                    </div>
                </div>
                <div class="info-item">
                    <i class="fas fa-phone"></i>
                    <div>
                        <h4>Phone</h4>
                        <a href="tel:+1234567890">+1 (234) 567-890</a>
                    </div>
                </div>
                <div class="social-links-contact">
                    <a href="https://instagram.com" target="_blank"><i class="fab fa-instagram"></i></a>
                    <a href="https://youtube.com" target="_blank"><i class="fab fa-youtube"></i></a>
                    <a href="https://linkedin.com" target="_blank"><i class="fab fa-linkedin"></i></a>
                </div>
            </div>
        </div>
    </section>

    <!-- Footer -->
    <footer class="footer">
        <p>&copy; 2025 s_design. All rights reserved.</p>
    </footer>

    <script src="js/app.js"></script>
</body>
</html>
